// backend/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // For Supabase, we don't use shadow database
  // shadowDatabaseUrl = env("SHADOW_DATABASE_URL") // Comment this out
}

model User {
  id        String    @id @default(cuid())
  username  String    @unique
  password  String
  isAdmin   Boolean   @default(false)
  createdAt DateTime  @default(now()) @db.Timestamptz(3) // Use timestamptz for Supabase
  updatedAt DateTime  @updatedAt @db.Timestamptz(3)

  // Relations
  userGroups UserGroup[]
  votes      Vote[]
}

model Group {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(3)

  // Relations
  userGroups   UserGroup[]
  matchResults MatchResult[]
}

model UserGroup {
  userId    String
  groupId   String
  points    Float     @default(0)
  joinedAt  DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @db.Timestamptz(3)

  // Relations
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([userId, groupId])
  @@index([groupId])
  @@index([userId])
}

model Match {
  id             String       @id @default(cuid())
  team1          String
  team2          String
  votingDeadline DateTime     @db.Timestamptz(3) // UTC time
  winningTeam    String?
  status         MatchStatus  @default(pending)
  createdAt      DateTime     @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime     @updatedAt @db.Timestamptz(3)

  // Relations
  votes        Vote[]
  matchResults MatchResult[]

  @@index([status])
  @@index([votingDeadline])
}

model Vote {
  id            String   @id @default(cuid())
  userId        String
  matchId       String
  selectedTeam  String
  createdAt     DateTime @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime @updatedAt @db.Timestamptz(3)

  // Relations
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([userId, matchId])
  @@index([matchId])
  @@index([userId])
}

model MatchResult {
  id            String   @id @default(cuid())
  matchId       String
  groupId       String
  winnerPoints  Float
  loserPoints   Float    @default(10)
  calculatedAt  DateTime @default(now()) @db.Timestamptz(3)

  // Relations
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([matchId, groupId])
  @@index([matchId])
  @@index([groupId])
}

enum MatchStatus {
  pending
  complete
}